{
  "$schema": "https://developer.microsoft.com/json-schemas/rush/v5/command-line.schema.json",
  "commands": [
    {
      "commandKind": "bulk",
      "name": "lint",
      "summary": "Runs lint scripts across projects.",
      "enableParallelism": true,
      "ignoreMissingScript": true
    },
    {
      "commandKind": "bulk",
      "name": "test",
      "summary": "Runs test scripts across projects.",
      "enableParallelism": true,
      "ignoreMissingScript": true,
      "allowWarningsInSuccessfulBuild": true
    },
    {
      "commandKind": "bulk",
      "name": "typecheck",
      "summary": "Runs static type/config checks across projects.",
      "enableParallelism": true,
      "ignoreMissingScript": true
    },
    {
      "commandKind": "global",
      "name": "web:dev",
      "summary": "Runs the Angular web app locally.",
      "safeForSimultaneousRushProcesses": true,
      "shellCommand": "cd apps/bookmark-cleaner && pnpm start"
    },
    {
      "commandKind": "global",
      "name": "worker:dev",
      "summary": "Runs the Cloudflare worker locally.",
      "safeForSimultaneousRushProcesses": true,
      "shellCommand": "cd services/link-health-worker && pnpm dev"
    }
  ],
  "parameters": []
}
